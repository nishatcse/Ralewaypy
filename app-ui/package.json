{
    "name": "raleway-booking-app",
    "version": "1.0.0",
    "description": "Standalone Railway Ticket Booking Application",
    "main": "dist/main/main.js",
    "author": "Md Abdullah Al Mamun",
    "license": "MIT",
    "scripts": {
        "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\" \"npm run dev:preload\"",
        "dev:renderer": "vite",
        "dev:main": "tsc -p tsconfig.main.json && cross-env NODE_ENV=development electron .",
        "dev:preload": "tsc -p tsconfig.preload.json --watch",
        "build": "npm run build:renderer && npm run build:main && npm run build:preload",
        "build:renderer": "vite build",
        "build:main": "tsc -p tsconfig.main.json",
        "build:preload": "tsc -p tsconfig.preload.json",
        "pack": "npm run build && electron-builder --dir",
        "dist": "npm run build && electron-builder",
        "dist:linux": "npm run build && electron-builder --linux",
        "dist:win": "npm run build && electron-builder --win",
        "postinstall": "electron-builder install-app-deps"
    },
    "dependencies": {
        "@fontsource/inter": "^5.2.8",
        "clsx": "^2.1.1",
        "lucide-react": "^0.554.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "tailwind-merge": "^3.4.0"
    },
    "devDependencies": {
        "@tailwindcss/forms": "^0.5.10",
        "@tailwindcss/typography": "^0.5.19",
        "@types/node": "^20.10.6",
        "@types/react": "^18.2.46",
        "@types/react-dom": "^18.2.18",
        "@vitejs/plugin-react": "^4.2.1",
        "autoprefixer": "^10.4.16",
        "concurrently": "^8.2.2",
        "cross-env": "^10.1.0",
        "electron": "^39.2.3",
        "electron-builder": "^24.9.1",
        "postcss": "^8.4.32",
        "tailwindcss": "^3.4.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.3.3",
        "vite": "^7.2.4",
        "vite-plugin-electron": "^0.28.1"
    },
    "build": {
        "appId": "com.mamun.raleway",
        "productName": "Raleway",
        "artifactName": "${productName}-${version}-${arch}.${ext}",
        "directories": {
            "output": "release",
            "buildResources": "build"
        },
        "files": [
            "dist/main/**/*",
            "dist/preload/**/*",
            "dist/renderer/**/*",
            "package.json"
        ],
        "extraResources": [
            {
                "from": "backend/dist/",
                "to": "backend/app/",
                "filter": ["**/*"]
            }
        ],
        "linux": {
            "target": [
                { "target": "AppImage", "arch": ["x64"] },
                { "target": "rpm", "arch": ["x64"] }
            ],
            "category": "Utility",
            "icon": "build/icon.png",
            "artifactName": "${productName}-${version}.${ext}"
        },
        "win": {
            "target": [
                { "target": "nsis", "arch": ["x64"] },
                { "target": "portable", "arch": ["x64"] }
            ],
            "icon": "build/icon.ico"
        },
        "nsis": {
            "oneClick": false,
            "perMachine": true,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "Raleway",
            "runAfterFinish": false,
            "artifactName": "${productName}-Installer-${version}.${ext}"
        }
    }
}